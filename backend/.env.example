# Firestore project. When FIRESTORE_EMULATOR_HOST is set, the client talks
# to the emulator instead of real Firestore regardless of this value.
GOOGLE_CLOUD_PROJECT=[[GCP_PROJECT_ID]]

# Uncomment for local development against the Firestore emulator instead of
# real Firestore (requires `gcloud emulators firestore start`):
# FIRESTORE_EMULATOR_HOST=localhost:8080

# GCS bucket for raw uploaded documents. If unset, an in-memory fake blob
# store is used instead (local dev / tests).
GCS_BUCKET_NAME=

# Max upload size in bytes for a workspace document.
MAX_UPLOAD_SIZE_BYTES=2000000

# Rate limits: max requests per window, per (workspace or IP), per endpoint.
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# Comma-separated list of allowed CORS origins for the frontend SPA.
ALLOW_ORIGINS=

# Base URL of a locally-running discussion-agent process (its
# reasoning_engine adapter routes: /api/reasoning_engine,
# /api/stream_reasoning_engine). Not yet an Agent Engine deployment — see
# docs/repo_configuration_progress.md.
DISCUSSION_AGENT_URL=http://localhost:8080

# Timeout (seconds) for a single discussion-agent HTTP call (session
# creation or a turn). Bounds how long a hung agent process can hold a
# backend request and a rate-limiter slot open.
DISCUSSION_AGENT_TIMEOUT_SECONDS=30

# Gemini access for the suggestions/journal plain LLM calls (app/llm_client.py).
# Defaults to Vertex AI, reusing GOOGLE_CLOUD_PROJECT above.
GOOGLE_GENAI_USE_ENTERPRISE=true
GOOGLE_CLOUD_LOCATION=global
# Alternatively, for Gemini API via Google AI Studio, comment out the two
# lines above and uncomment:
# GEMINI_API_KEY=[[GEMINI_API_KEY]]

# Models for the two plain (non-agent) LLM calls. Evergreen aliases resolve
# for the Flash tier on this project/region as of 2026-07-07 — re-check at
# the next implementation touch point (see technical_specification.md §8).
SUGGESTIONS_MODEL=gemini-flash-latest
JOURNAL_MODEL=gemini-flash-latest

# Timeout (seconds) for a single suggestions/journal LLM call.
LLM_TIMEOUT_SECONDS=15
